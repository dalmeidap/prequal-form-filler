{
  "manifest_version": 3,
  "name": "Prequal Form Filler",
  "version": "0.0.1",
  "description": "Fill Octane Prequal forms with test profiles",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16x16.png",
      "48": "icons/icon-32x32.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:*/*", "https://*.qa-eks.octane.co/*", "https://*.sandbox-eks.octane.co/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
