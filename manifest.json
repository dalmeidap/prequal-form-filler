{
  "manifest_version": 3,
  "name": "Octane Form Filler",
  "version": "1.0.0",
  "description": "Fill Octane apply forms with test profiles",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:*/*", "https://*.octane.co/*", "https://*.sandbox-eks.octane.co/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
